# ==============================
# SERVER
# ==============================
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ==============================
# DATABASE
# Replace with your own MongoDB Atlas connection string
# Example: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/portfolio?retryWrites=true&w=majority
# ==============================
MONGO_URI=your_mongodb_atlas_connection_string_here

# ==============================
# JWT AUTH
# Generate a strong secret, e.g.: openssl rand -base64 48
# ==============================
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# ==============================
# CLOUDINARY (for image/resume uploads)
# Get these from https://cloudinary.com/console
# ==============================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================
# ADMIN SEED ACCOUNT
# Used only by `npm run seed` to create the first admin user.
# CHANGE THE PASSWORD before running in any shared/production environment.
# ==============================
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe_StrongPassword123!

# ==============================
# EMAIL (for contact form notifications) - optional
# ==============================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
CONTACT_RECEIVER_EMAIL=your_email@gmail.com

# ==============================
# RATE LIMITING
# ==============================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
